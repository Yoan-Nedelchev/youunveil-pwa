# Copy to .env.local and fill in (do not commit real values).

# Public (bundled for the browser) — safe to expose; security is RLS + Auth.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server + build: mapped to NEXT_PUBLIC_SUPABASE_URL in next.config.ts for the client.
SUPABASE_URL=

# Server only: Drizzle / Postgres (pooler URL recommended on Vercel).
POSTGRES_PRISMA_URL=

# --- Optional (uncomment when needed) ---

# Server only: Google Gemini (e.g. hero inquiry on the landing page).
# GEMINI_API_KEY=

# Supabase Auth (OAuth / email confirmation): add these redirect URLs in the
# Supabase dashboard (Authentication → URL configuration) for each environment:
#   http://localhost:3000/en/auth/callback
#   http://localhost:3000/bg/auth/callback
#   https://<your-domain>/en/auth/callback
#   https://<your-domain>/bg/auth/callback

# NEXT_PUBLIC_SUPABASE_GRAPHQL_URL=

# ENABLE_DB_HEALTH=1

# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_JWT_SECRET=

# WEB_PUSH_PUBLIC_KEY=
# WEB_PUSH_PRIVATE_KEY=
