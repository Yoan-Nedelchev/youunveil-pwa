# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase GraphQL (typically https://<project-ref>.supabase.co/graphql/v1)
NEXT_PUBLIC_SUPABASE_GRAPHQL_URL=

# Postgres connection string (Settings → Database; use pooler for serverless)
DATABASE_URL=

# Optional: VAPID keys for web-push (generate when you add push)
# WEB_PUSH_PUBLIC_KEY=
# WEB_PUSH_PRIVATE_KEY=
